# ===========================================
# Open Brain - Environment Configuration
# ===========================================

# DATABASE (Required)
DB_PASSWORD=openbrain
DB_HOST=localhost
DB_PORT=5433
DB_NAME=openbrain
DB_USER=postgres

# EMBEDDING PROVIDER (Required for semantic search)
# Choose: openrouter, openai, ollama, custom
EMBEDDER_PROVIDER=openrouter

# OpenRouter (FREE - recommended)
OPENROUTER_API_KEY=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

# OR OpenAI
# OPENAI_API_KEY=your_openai_api_key

# OR Ollama (local)
# OLLAMA_BASE_URL=http://localhost:11434

# OR Custom (any OpenAI-compatible API)
# CUSTOM_API_URL=https://api.example.com/v1
# CUSTOM_API_KEY=your_custom_api_key

# PORTS
MCP_PORT=8080
API_PORT=8000
DASHBOARD_PORT=8501

# NOTIFICATIONS (Optional)
# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=your_email@gmail.com

# SECURITY
SECURITY_MODE=direct

