# ===========================================
# Open Brain - Environment Configuration
#
# Copy this file to `.env` and edit the values for your environment.
# `openbrain configure --project-root .` will fill in DB_PASSWORD and
# OPENBRAIN_API_KEY automatically on first run.
# ===========================================

# DATABASE (Required)
DB_PASSWORD=replace-with-a-random-password
DB_HOST=localhost
DB_PORT=5433
DB_HOST_PORT=5433
DB_NAME=openbrain
DB_USER=postgres
DB_TIMEZONE=auto

# EMBEDDING PROVIDER (Required for semantic search)
#
# The docker-compose stack ships an `ollama` service that runs the
# `nomic-embed-text` model locally — no external API key required.
# That is the recommended default. To use a hosted provider instead,
# set EMBEDDER_PROVIDER and provide the matching API key below.
#
# Choose: ollama, openrouter, openai, custom
EMBEDDER_PROVIDER=ollama

# Ollama (local; default — no API key required)
# Inside the docker network the api reaches ollama at http://ollama:11434
# (compose sets OLLAMA_BASE_URL automatically).
# To run a standalone Ollama on the host, change to http://localhost:11434
# OLLAMA_BASE_URL=http://ollama:11434

# OR OpenRouter (hosted; API key required)
# OPENROUTER_API_KEY=your_openrouter_api_key

# OR OpenAI
# OPENAI_API_KEY=your_openai_api_key

# OR Custom (any OpenAI-compatible API)
# CUSTOM_API_URL=https://api.example.com/v1
# CUSTOM_API_KEY=your_custom_api_key

# SERVICE PORTS
#
# The api is published on the host as 127.0.0.1:${API_PORT}:8000. The default
# of 8765 avoids the Windows IP Helper service (iphlpsvc), which often holds
# 8000. Override here if you need a different port.
API_PORT=8765
DASHBOARD_PORT=8501

# API OPERATIONS
# production enables authentication by default and refuses to start without
# OPENBRAIN_API_KEY. Generated automatically by `openbrain configure`.
OPENBRAIN_ENV=development
# OPENBRAIN_API_KEY=managed-automatically
# OPENBRAIN_AUTH_REQUIRED=true
OPENBRAIN_MAX_REQUEST_BYTES=1048576
OPENBRAIN_RATE_LIMIT_REQUESTS=120
OPENBRAIN_RATE_LIMIT_WINDOW_SECONDS=60
OPENBRAIN_TRUST_PROXY_HEADERS=false
OPENBRAIN_CORS_ORIGINS=http://localhost:8501,http://localhost:8765

# NOTIFICATIONS (Optional)
# Telegram
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# EMAIL_FROM=your_email@gmail.com

# SECURITY
SECURITY_MODE=direct
